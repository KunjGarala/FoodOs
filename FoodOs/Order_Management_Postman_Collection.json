            "url": {
              "raw": "{{baseUrl}}/orders/{{orderUuid}}/items/{{itemUuid}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderUuid}}", "items", "{{itemUuid}}", "cancel"]
            }
          },
          "response": []
        }
      ]
    },
