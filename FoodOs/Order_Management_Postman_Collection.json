        {
          "name": "Add Payment - UPI",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentMethod\": \"UPI\",\n  \"amount\": 750.00,\n  \"transactionId\": \"UPI123456\",\n  \"upiId\": \"customer@paytm\",\n  \"notes\": \"UPI payment\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderUuid}}/payments",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderUuid}}", "payments"]
            }
          },
          "response": []
        },
        {
          "name": "Get Orders with Pending Payments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/restaurant/{{restaurantId}}/pending-payments",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "restaurant", "{{restaurantId}}", "pending-payments"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Order Items",
      "item": [
        {
          "name": "Add Items to Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"productId\": 4,\n    \"quantity\": 1,\n    \"unitPrice\": 180.00,\n    \"itemNotes\": \"No onions\"\n  }\n]"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderUuid}}/items",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderUuid}}", "items"]
            }
          },
          "response": []
