                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentMethod\": \"CARD\",\n  \"amount\": 500.00,\n  \"transactionId\": \"TXN123456789\",\n  \"cardLastFour\": \"1234\",\n  \"cardType\": \"VISA\",\n  \"notes\": \"Card payment\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderUuid}}/payments",
              "host": ["{{baseUrl}}"],
              "path": ["orders", "{{orderUuid}}", "payments"]
            }
          },
          "response": []
