	},
	"item": [
		{
			"name": "Create Product",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "multipart/form-data"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "product",
							"value": "{\n    \"name\": \"Classic Burger\",\n    \"description\": \"A delicious classic burger.\",\n    \"price\": 9.99,\n    \"categoryUuid\": \"{{categoryUuid}}\",\n    \"sku\": \"BURGER-001\",\n    \"isFeatured\": true\n}",
							"type": "text"
						}
					]
				},
				"url": {
					"raw": "{{baseUrl}}/api/restaurants/{{restaurantUuid}}/products/create",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"restaurants",
						"{{restaurantUuid}}",
						"products",
						"create"
					]
				}
			},
			"response": []
		},
